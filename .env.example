# ─── Backend (apps/api) ───────────────────────────────────────────────
# MongoDB connection string.
# Atlas: mongodb+srv://<user>:<pw>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Local Docker: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Database name inside the cluster (defaults to "blog" if unset).
MONGODB_DB=blog

# HS256 signing secret for JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-64-char-random-hex

# OpenRouter API key (unified gateway to Claude, GPT, Llama, etc.)
# Get one at https://openrouter.ai/keys — keys start with sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: which model OpenRouter should route to. Defaults to anthropic/claude-sonnet-4.5.
# Other useful choices: anthropic/claude-haiku-4.5 (faster/cheaper), openai/gpt-4o-mini (cheapest)
# See https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Optional: cheaper/faster fallback model when the primary is unavailable.
# Only used on cold-start failures — never mid-stream. Defaults to anthropic/claude-haiku-4.5.
OPENROUTER_FALLBACK_MODEL=anthropic/claude-haiku-4.5

# ─── RAG / embeddings (optional but recommended) ──────────────────────
# OpenAI-compatible embedding endpoint. As of 2026 OpenRouter does not proxy
# embeddings, so point at OpenAI directly (or a self-hosted server like
# Ollama/vLLM). When unset, retrieval falls back to lexical-only.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# How many chunks to retrieve for grounding each chat turn (1-20). Default 5.
CHAT_RETRIEVAL_K=5

# Token budget for prior-turn history after system prompt is subtracted.
# Sliding-window trim keeps most-recent messages within this cap. Default 6000.
CHAT_HISTORY_TOKEN_BUDGET=6000

# ─── Observability ────────────────────────────────────────────────────
# Structured-log verbosity: debug | info | warn | error. Default info.
LOG_LEVEL=info

# Comma-separated allow-list of CORS origins. The API echoes back whichever
# entry matches the incoming request's Origin header. Local dev includes both
# `localhost` and `127.0.0.1` (browsers treat them as distinct origins even
# though they resolve to the same IP).
CORS_ALLOWED_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend (apps/web, Vite reads VITE_* only) ──────────────────────
# REST API base URL. Local dev = http://localhost:3000
VITE_API_URL=http://localhost:3000

# AI chat streaming endpoint URL. Local dev = http://localhost:3000/chat
VITE_CHAT_URL=http://localhost:3000/chat

# ─── Deploy (infra) ───────────────────────────────────────────────────
# Optional: override AWS region (defaults to us-east-1)
AWS_REGION=us-east-1
